# Chave global da Evolution API (header: apikey)
AUTHENTICATION_API_KEY=mude-me-para-uma-chave-segura

# URL pública/acessível da Evolution API
SERVER_URL=http://localhost:8080

# Banco de dados PostgreSQL (serviço postgres do compose)
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution_pass@postgres:5432/evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true
DATABASE_CONNECTION_CLIENT_NAME=moneyconnect_evolution

# Redis
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/1
CACHE_REDIS_PREFIX_KEY=moneyconnect_evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# Webhook global (opcional — preferimos webhook por instância via Django)
WEBHOOK_GLOBAL_ENABLED=false

# Logs
LOG_LEVEL=ERROR,WARN,DEBUG,INFO,LOG,VERBOSE,DARK,WEBHOOKS

# WhatsApp Web / QR Code — deixe vazio para buscar versão automaticamente
CONFIG_SESSION_PHONE_VERSION=
CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30

# Desativa modo LID para receber JIDs com número real (@s.whatsapp.net)
WPP_LID_MODE=false
