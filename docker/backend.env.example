# Django / Celery / Channels
DJANGO_SECRET_KEY=mude-me-para-uma-chave-segura
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,host.docker.internal

# CORS (frontend via nginx na porta 5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL do app (serviço postgres-app)
POSTGRES_HOST=postgres-app
POSTGRES_PORT=5432
POSTGRES_DB=moneyconnect
POSTGRES_USER=moneyconnect
POSTGRES_PASSWORD=moneyconnect_pass

# Redis — db 0: Celery | db 1: Evolution | db 2: Django Channels | db 3: Cache segurança
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CHANNELS_URL=redis://redis:6379/2
REDIS_CACHE_URL=redis://redis:6379/3
# Em produção, configure REDIS_PASSWORD no Redis e use redis://:senha@redis:6379/N
# REDIS_PASSWORD=
USE_REDIS_CHANNELS=true

# Segurança — anti-bruteforce e rate limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=30
AUTH_RATE_LIMIT=10/min
API_RATE_LIMIT_ANON=30/min
API_RATE_LIMIT_USER=120/min
CNPJ_LOOKUP_RATE_LIMIT=20/min
WEBHOOK_RATE_LIMIT_PER_MINUTE=120
DEEPSEEK_RATE_LIMIT=10/min
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
# HSTS: defina >0 apenas com HTTPS em produção (ex: 31536000)
SECURE_HSTS_SECONDS=31536000

# Celery
USE_CELERY=true
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Evolution API (rede interna Docker)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=mude-me-para-uma-chave-segura
EVOLUTION_WEBHOOK_BASE_URL=http://backend:8000/api/webhooks

# Meta Cloud API (opcional)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0

# Fase 3 — JWT cookies, 2FA, CAPTCHA, criptografia
JWT_ACCESS_COOKIE_NAME=wc_access
JWT_REFRESH_COOKIE_NAME=wc_refresh
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
# Durante rotação: chave anterior até concluir rotate_field_encryption_key
FIELD_ENCRYPTION_KEY_OLD=
CAPTCHA_AFTER_FAILURES=3
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
ADMIN_ENABLED=true
# Papéis obrigados a configurar 2FA (superuser,gestor)
TOTP_REQUIRED_ROLES=superuser,gestor
# Dispositivo confiável — pula 2FA no mesmo navegador (dias)
TRUSTED_DEVICE_DAYS=30
TRUSTED_DEVICE_COOKIE_NAME=wc_trusted
# Webhook Discord/Slack para alertas de segurança (opcional)
SECURITY_ALERT_WEBHOOK_URL=

# Admin inicial (create_admin) — mínimo 10 caracteres; troque em produção
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=AltereEstaSenha1!
DJANGO_ADMIN_EMAIL=admin@weconnect.local
