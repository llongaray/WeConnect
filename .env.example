# Django
DJANGO_SECRET_KEY=troque-por-uma-chave-segura
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal

# CORS (frontend Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis (Django Channels — produção)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Evolution API (canais evolution_normal e evolution_business)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=mude-me-para-uma-chave-segura
EVOLUTION_WEBHOOK_BASE_URL=http://host.docker.internal:8000/api/webhooks

# Meta Cloud API (canais meta_cloud — OAuth na fase 2)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0

# DeepSeek API (opcional — token configurado via painel admin)
